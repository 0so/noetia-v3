{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/buttons/**",
              "components/controls/**",
              "components/layout/**",
              "components/surfaces/**",
              "ui_kits/aura_landing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter))/i]",
        "message": "Font not provided by the design system. Available: Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppleButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|full|onClick|className|style|key|ref|className|style|children)$/]",
        "message": "<AppleButton> doesn't accept that prop. Declared props: label, full, onClick, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppleLogo'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|className|style|key|ref|className|style|children)$/]",
        "message": "<AppleLogo> doesn't accept that prop. Declared props: size, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BillingToggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|className|style|key|ref|className|style|children)$/]",
        "message": "<BillingToggle> doesn't accept that prop. Declared props: checked, onChange, label, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|className|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='GhostButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|chevron|onClick|className|style|key|ref|className|style|children)$/]",
        "message": "<GhostButton> doesn't accept that prop. Declared props: label, chevron, onClick, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='LiquidGlassCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|radius|padding|glow|as|className|style|key|ref|className|style|children)$/]",
        "message": "<LiquidGlassCard> doesn't accept that prop. Declared props: children, radius, padding, glow, as, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='LiquidGlassCard'] > JSXAttribute[name.name='radius'] > Literal[value!=/^(?:md|lg|xl)$/]",
        "message": "<LiquidGlassCard> radius must be one of 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LogoMark'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|fill|className|style|key|ref|className|style|children)$/]",
        "message": "<LogoMark> doesn't accept that prop. Declared props: size, fill, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionEyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|tag|className|style|key|ref|className|style|children)$/]",
        "message": "<SectionEyebrow> doesn't accept that prop. Declared props: label, tag, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ShinyText'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|as|animate|withFilter|className|style|key|ref|className|style|children)$/]",
        "message": "<ShinyText> doesn't accept that prop. Declared props: children, as, animate, withFilter, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrafficLights'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|gap|className|style|key|ref|className|style|children)$/]",
        "message": "<TrafficLights> doesn't accept that prop. Declared props: size, gap, className, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
